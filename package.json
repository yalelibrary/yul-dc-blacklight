{
  "name": "blacklight_yul",
  "private": true,
  "dependencies": {
    "universalviewer": "4.2.0-rc4"
  },
  "resolutions": {
    "form-data": "4.0.6",
    "brace-expansion": "2.0.3",
    "filelist/minimatch": "^5.1.8"
  },
  "scripts": {
    "preinstall": "rm -rf ./public/uv",
    "postinstall": "yarn run uv-install && yarn run uv-config",
    "uv-install": "shx cp -r ./node_modules/universalviewer/dist ./public/uv",
    "uv-config": "shx cp ./config/uv/uv.html ./public/uv/uv.html & shx cp ./config/uv/uv-config.json ./public/uv/"
  },
  "version": "0.1.0",
  "devDependencies": {
    "shx": "^0.3.2"
  }
}
